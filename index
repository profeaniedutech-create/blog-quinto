function renderPosts(cat){
  const container=document.getElementById('posts-container');
  const paginationEl=document.getElementById('pagination');
  let posts=[...state.posts];
  if(cat!=='all') posts=posts.filter(p=>p.category===cat);
  if(!posts.length){
    container.innerHTML=`<div class="empty-state"><div class="emoji">📭</div><h3>¡Nadie escribió todavía!</h3><p>Sé el primero en compartir algo de este proyecto.</p>${state.currentUser&&!state.currentUser.isAdmin?'<button class="btn-primary" onclick="w.goWrite()">✏️ Escribir ahora</button>':''}</div>`;
    paginationEl.innerHTML='';return;
  }
  const totalPages=Math.ceil(posts.length/POSTS_PER_PAGE);
  if(state.currentPage>totalPages) state.currentPage=totalPages;
  const start=(state.currentPage-1)*POSTS_PER_PAGE;
  container.innerHTML=`<div class="posts-grid">${posts.slice(start,start+POSTS_PER_PAGE).map(postCard).join('')}</div>`;
  if(totalPages<=1){paginationEl.innerHTML='';return;}
  let ph=`<button class="page-btn" onclick="w.changePage(${state.currentPage-1})" ${state.currentPage===1?'disabled':''}>← Anterior</button>`;
  for(let i=1;i<=totalPages;i++) ph+=`<button class="page-btn ${i===state.currentPage?'active':''}" onclick="w.changePage(${i})">${i}</button>`;
  ph+=`<button class="page-btn" onclick="w.changePage(${state.currentPage+1})" ${state.currentPage===totalPages?'disabled':''}>Siguiente →</button>`;
  paginationEl.innerHTML=ph;
}
