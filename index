<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Amigos de 5° Hugo Leonelli</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --sky:#3B82F6;--sky-light:#EFF6FF;--sun:#F59E0B;--green:#10B981;--green-light:#ECFDF5;
    --coral:#F43F5E;--coral-light:#FFF1F2;--purple:#8B5CF6;--purple-light:#F5F3FF;
    --teal:#0D9488;--teal-light:#F0FDFA;--bg:#F8FAFF;--white:#ffffff;
    --text:#1e293b;--muted:#64748b;--border:#e2e8f0;--radius:16px;
    --shadow:0 4px 24px rgba(59,130,246,0.10);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
  .view{display:none;}.view.active{display:block;}

  /* HEADER */
  header{background:linear-gradient(135deg,#0D9488 0%,#3B82F6 50%,#8B5CF6 100%);position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(13,148,136,.30);}
  .header-inner{max-width:1100px;margin:0 auto;padding:14px 28px;display:flex;align-items:center;justify-content:space-between;}
  .logo{font-family:'Fredoka One',cursive;font-size:22px;color:white;display:flex;align-items:center;gap:10px;cursor:pointer;background:none;border:none;}
  .logo span{font-size:28px;}
  .header-nav{display:flex;align-items:center;gap:10px;}
  .btn-header{padding:8px 18px;border-radius:50px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;border:none;transition:all .2s;}
  .btn-outline-white{background:rgba(255,255,255,.18);color:white;border:1.5px solid rgba(255,255,255,.5);}
  .btn-outline-white:hover{background:rgba(255,255,255,.30);}
  .btn-white{background:white;color:var(--teal);}
  .btn-white:hover{background:var(--teal-light);}
  #user-badge{background:rgba(255,255,255,.22);color:white;padding:6px 14px;border-radius:50px;font-size:13px;font-weight:700;display:none;align-items:center;gap:6px;}
  #user-badge.visible{display:flex;}

  /* HERO */
  .hero{background:linear-gradient(160deg,#F0FDFA 0%,#EFF6FF 50%,#F5F3FF 100%);padding:70px 28px 50px;text-align:center;}
  .hero-badge{display:inline-block;background:var(--teal-light);color:#134E4A;border:1.5px solid #99F6E4;border-radius:50px;padding:6px 18px;font-size:13px;font-weight:800;margin-bottom:20px;}
  .hero h1{font-family:'Fredoka One',cursive;font-size:clamp(32px,5.5vw,58px);line-height:1.1;background:linear-gradient(135deg,#0D9488,#3B82F6,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:18px;}
  .hero p{max-width:560px;margin:0 auto 32px;font-size:17px;color:var(--muted);line-height:1.7;}
  .hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
  .btn-primary{background:linear-gradient(135deg,#0D9488,#3B82F6);color:white;border:none;padding:14px 32px;border-radius:50px;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;cursor:pointer;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 20px rgba(13,148,136,.35);}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(13,148,136,.40);}
  .btn-primary:disabled{opacity:.6;transform:none;cursor:not-allowed;}
  .btn-secondary{background:white;color:var(--teal);border:2px solid #99F6E4;padding:14px 32px;border-radius:50px;font-family:'Nunito',sans-serif;font-size:16px;font-weight:700;cursor:pointer;transition:all .2s;}
  .btn-secondary:hover{border-color:var(--teal);background:var(--teal-light);}
  .floating-icons{display:flex;justify-content:center;gap:20px;margin-top:40px;font-size:40px;flex-wrap:wrap;}
  .float-icon{animation:float 3s ease-in-out infinite;display:inline-block;filter:drop-shadow(0 4px 6px rgba(0,0,0,.08));}
  .float-icon:nth-child(2){animation-delay:.5s;}.float-icon:nth-child(3){animation-delay:1s;}
  .float-icon:nth-child(4){animation-delay:1.5s;}.float-icon:nth-child(5){animation-delay:2s;}
  @keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}

  /* SECTION */
  .section{max-width:1100px;margin:0 auto;padding:60px 28px;}
  .section-title{font-family:'Fredoka One',cursive;font-size:32px;color:var(--text);margin-bottom:8px;}
  .section-sub{color:var(--muted);font-size:16px;margin-bottom:32px;}

  /* CARDS */
  .posts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;}
  .post-card{background:white;border-radius:var(--radius);border:1.5px solid var(--border);overflow:hidden;transition:transform .2s,box-shadow .2s;cursor:pointer;}
  .post-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);}
  .card-banner{height:110px;display:flex;align-items:center;justify-content:center;font-size:46px;position:relative;overflow:hidden;}
  .card-banner-img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}
  .card-banner-emoji{position:relative;z-index:1;font-size:46px;}
  .card-type-badge{position:absolute;top:8px;right:8px;z-index:2;background:rgba(255,255,255,.85);border-radius:6px;padding:3px 7px;font-size:10px;font-weight:800;color:#475569;text-transform:uppercase;letter-spacing:.3px;}
  .card-body{padding:18px;}
  .card-category{display:inline-block;font-size:11px;font-weight:800;padding:4px 10px;border-radius:50px;margin-bottom:10px;letter-spacing:.4px;text-transform:uppercase;}
  .card-title{font-size:16px;font-weight:800;margin-bottom:8px;line-height:1.4;color:var(--text);}
  .card-excerpt{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
  .card-footer{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--muted);border-top:1px solid var(--border);padding-top:12px;}
  .card-author{display:flex;align-items:center;gap:6px;font-weight:700;}
  .avatar-mini{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:white;flex-shrink:0;}

  /* STATS */
  .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px;margin-bottom:48px;}
  .stat-card{background:white;border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;}
  .stat-num{font-family:'Fredoka One',cursive;font-size:36px;margin-bottom:4px;}
  .stat-label{font-size:13px;color:var(--muted);font-weight:600;}

  /* TABS */
  .tabs{display:flex;gap:6px;margin-bottom:28px;flex-wrap:wrap;}
  .tab{padding:8px 16px;border-radius:50px;font-size:13px;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:white;color:var(--muted);transition:all .2s;white-space:nowrap;}
  .tab.active{background:var(--teal);color:white;border-color:var(--teal);}
  .tab:hover:not(.active){border-color:var(--teal);color:var(--teal);}

  /* PAGINATION */
  .pagination{display:flex;gap:8px;justify-content:center;margin-top:32px;flex-wrap:wrap;}
  .page-btn{padding:8px 16px;border-radius:10px;border:1.5px solid var(--border);background:white;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;color:var(--muted);transition:all .2s;}
  .page-btn.active{background:var(--teal);color:white;border-color:var(--teal);}
  .page-btn:hover:not(.active):not(:disabled){border-color:var(--teal);color:var(--teal);}
  .page-btn:disabled{opacity:.4;cursor:not-allowed;}

  /* OVERLAY / MODAL */
  .overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:200;align-items:center;justify-content:center;padding:20px;overflow-y:auto;}
  .overlay.open{display:flex;}
  .modal{background:white;border-radius:24px;width:100%;max-width:520px;padding:36px;position:relative;animation:slideUp .3s ease;margin:auto;}
  @keyframes slideUp{from{transform:translateY(30px);opacity:0;}to{transform:translateY(0);opacity:1;}}
  .modal-close{position:absolute;top:16px;right:16px;background:var(--border);border:none;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:background .2s;}
  .modal-close:hover{background:#cbd5e1;}
  .modal-title{font-family:'Fredoka One',cursive;font-size:24px;margin-bottom:6px;}
  .modal-sub{color:var(--muted);font-size:14px;margin-bottom:24px;}
  .form-group{margin-bottom:16px;}
  .form-label{font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:6px;}
  .form-input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:12px;font-family:'Nunito',sans-serif;font-size:15px;color:var(--text);transition:border-color .2s;outline:none;}
  .form-input:focus{border-color:var(--teal);}
  .form-select{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:12px;font-family:'Nunito',sans-serif;font-size:15px;color:var(--text);outline:none;background:white;cursor:pointer;}
  .form-select:focus{border-color:var(--teal);}
  .form-textarea{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:12px;font-family:'Nunito',sans-serif;font-size:15px;color:var(--text);resize:vertical;min-height:130px;outline:none;}
  .form-textarea:focus{border-color:var(--teal);}
  .error-msg{background:#FFF1F2;color:#BE123C;border:1px solid #FECDD3;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;margin-bottom:14px;display:none;}
  .success-msg{background:var(--green-light);color:#065F46;border:1px solid #A7F3D0;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;margin-bottom:14px;display:none;}
  .info-msg{background:#EFF6FF;color:#1E40AF;border:1px solid #BFDBFE;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;margin-bottom:14px;}

  /* PASSWORD STRENGTH */
  .pass-strength{margin-top:6px;font-size:12px;font-weight:700;}
  .pass-strength.weak{color:#BE123C;}.pass-strength.medium{color:#D97706;}.pass-strength.strong{color:#065F46;}

  /* FILE UPLOAD */
  .file-upload-area{border:2px dashed #CBD5E1;border-radius:14px;padding:24px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:12px;position:relative;}
  .file-upload-area:hover,.file-upload-area.drag-over{border-color:var(--teal);background:var(--teal-light);}
  .file-upload-area input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
  .file-upload-icon{font-size:32px;margin-bottom:8px;}
  .file-upload-text{font-size:14px;color:var(--muted);font-weight:600;}
  .file-upload-hint{font-size:12px;color:#94A3B8;margin-top:4px;}
  .file-preview{display:flex;align-items:center;gap:10px;background:#F8FAFF;border:1px solid var(--border);border-radius:10px;padding:10px 14px;margin-top:8px;font-size:13px;}
  .file-preview .file-icon{font-size:22px;flex-shrink:0;}
  .file-preview .file-name{font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .file-preview .remove-file{background:none;border:none;cursor:pointer;color:var(--coral);font-size:18px;padding:0;flex-shrink:0;}
  .content-type-tabs{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
  .ctype-tab{padding:7px 14px;border-radius:10px;border:1.5px solid var(--border);background:white;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;color:var(--muted);}
  .ctype-tab.active{background:var(--teal);color:white;border-color:var(--teal);}
  .ctype-tab:hover:not(.active){border-color:var(--teal);color:var(--teal);}

  /* UPLOAD PROGRESS */
  .upload-progress-wrap{margin-top:10px;}
  .upload-progress-label{font-size:12px;color:var(--muted);font-weight:600;margin-bottom:4px;display:flex;justify-content:space-between;}
  .upload-progress-bar{height:6px;background:#E2E8F0;border-radius:10px;overflow:hidden;}
  .upload-progress-fill{height:100%;border-radius:10px;background:linear-gradient(90deg,var(--teal),var(--sky));transition:width .3s;}

  /* LOADING */
  .loading-overlay{position:fixed;inset:0;background:rgba(248,250,255,.9);z-index:300;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
  .loading-overlay.hidden{display:none;}
  .spinner{width:44px;height:44px;border:4px solid #E2E8F0;border-top-color:var(--teal);border-radius:50%;animation:spin .8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .loading-text{font-weight:700;color:var(--muted);font-size:15px;}

  /* TOAST */
  .toast-container{position:fixed;bottom:24px;right:24px;z-index:400;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
  .toast{background:#1e293b;color:white;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:700;animation:toastIn .3s ease;pointer-events:auto;max-width:320px;display:flex;align-items:center;gap:10px;}
  .toast.success{background:#065F46;}.toast.error{background:#BE123C;}.toast.warning{background:#92400E;}
  @keyframes toastIn{from{transform:translateX(100px);opacity:0;}to{transform:translateX(0);opacity:1;}}
  @keyframes toastOut{to{transform:translateX(120px);opacity:0;}}

  /* POST READ */
  .post-full{max-width:740px;margin:0 auto;padding:40px 28px;}
  .post-full-header{margin-bottom:28px;}
  .post-full-category{display:inline-block;font-size:12px;font-weight:800;padding:5px 14px;border-radius:50px;margin-bottom:14px;text-transform:uppercase;letter-spacing:.4px;}
  .post-full h1{font-family:'Fredoka One',cursive;font-size:34px;line-height:1.2;margin-bottom:16px;}
  .post-meta{display:flex;align-items:center;gap:12px;color:var(--muted);font-size:14px;flex-wrap:wrap;}
  .post-full-body{font-size:17px;line-height:1.85;color:#334155;white-space:pre-wrap;margin-top:28px;padding-top:28px;border-top:1.5px solid var(--border);}
  .post-attachment{margin-top:24px;padding-top:20px;border-top:1px solid var(--border);}
  .post-attachment-title{font-size:13px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:12px;}
  .attachment-card{display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1.5px solid var(--border);border-radius:12px;padding:14px 18px;cursor:pointer;transition:all .2s;}
  .attachment-card:hover{border-color:var(--teal);background:var(--teal-light);}
  .attachment-card .att-icon{font-size:28px;flex-shrink:0;}
  .attachment-card .att-info{flex:1;}
  .attachment-card .att-name{font-weight:700;font-size:14px;}
  .attachment-card .att-type{font-size:12px;color:var(--muted);margin-top:2px;}
  .post-image-full{max-width:100%;border-radius:12px;margin-top:20px;border:1.5px solid var(--border);}
  .post-audio{width:100%;margin-top:16px;border-radius:12px;}
  .post-video{width:100%;border-radius:12px;margin-top:16px;max-height:400px;}
  .edit-actions{display:flex;gap:10px;margin-top:28px;padding-top:20px;border-top:1px solid var(--border);}

  /* WRITE */
  .write-container{max-width:740px;margin:0 auto;padding:40px 28px;}
  .write-header{display:flex;align-items:center;gap:14px;margin-bottom:32px;}
  .write-header h2{font-family:'Fredoka One',cursive;font-size:28px;}
  .back-btn{background:var(--border);border:none;padding:8px 16px;border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;color:var(--muted);transition:background .2s;}
  .back-btn:hover{background:#CBD5E1;}

  /* ADMIN */
  .admin-panel{background:white;border-radius:var(--radius);border:1.5px solid var(--border);overflow:hidden;}
  .admin-panel-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
  .admin-panel-header h3{font-family:'Fredoka One',cursive;font-size:20px;}
  .table-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:14px;}
  th{background:#F8FAFF;padding:12px 18px;text-align:left;font-size:11px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);}
  td{padding:13px 18px;border-bottom:1px solid #F1F5F9;}
  tr:last-child td{border-bottom:none;}
  .badge{display:inline-block;padding:3px 10px;border-radius:50px;font-size:11px;font-weight:800;}
  .badge-green{background:var(--green-light);color:#065F46;}
  .btn-sm{padding:5px 12px;border-radius:8px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;cursor:pointer;border:1px solid;transition:all .2s;}
  .btn-danger{border-color:#FECDD3;background:#FFF1F2;color:#BE123C;}
  .btn-danger:hover{background:#FECDD3;}
  .btn-success{border-color:#99F6E4;background:var(--teal-light);color:#134E4A;}
  .btn-success:hover{background:#99F6E4;}

  /* SECTION PILLS */
  .section-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:50px;font-size:13px;font-weight:700;border:1.5px solid var(--border);background:white;margin:4px;}
  .section-pill button{background:none;border:none;cursor:pointer;color:var(--coral);font-size:14px;line-height:1;padding:0;margin-left:2px;}

  /* EMPTY STATE */
  .empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
  .empty-state .emoji{font-size:60px;margin-bottom:16px;}
  .empty-state h3{font-family:'Fredoka One',cursive;font-size:22px;color:var(--text);margin-bottom:8px;}
  .empty-state p{font-size:15px;max-width:340px;margin:0 auto 20px;}

  /* FIREBASE STATUS */
  .fb-status{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;padding:4px 12px;border-radius:50px;}
  .fb-status.online{background:#ECFDF5;color:#065F46;}
  .fb-status.offline{background:#FFF1F2;color:#BE123C;}
  .fb-status.connecting{background:#FFFBEB;color:#78350F;}
  .fb-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .fb-status.online .fb-dot{background:#10B981;}
  .fb-status.offline .fb-dot{background:#F43F5E;}
  .fb-status.connecting .fb-dot{background:#F59E0B;animation:pulse 1s infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}


  /* RECURSOS DIGITALES */
  .recursos-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:32px;}
  .recurso-card{background:white;border-radius:var(--radius);border:1.5px solid var(--border);overflow:hidden;transition:transform .2s,box-shadow .2s;text-decoration:none;display:block;color:var(--text);}
  .recurso-card:hover{transform:translateY(-6px);box-shadow:0 12px 40px rgba(0,0,0,.12);}
  .recurso-banner{height:130px;display:flex;align-items:center;justify-content:center;font-size:56px;position:relative;}
  .recurso-body{padding:20px;}
  .recurso-title{font-family:'Fredoka One',cursive;font-size:20px;margin-bottom:6px;line-height:1.2;}
  .recurso-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
  .recurso-cta{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:800;padding:8px 16px;border-radius:50px;color:white;transition:opacity .2s;}
  .recurso-cta:hover{opacity:.85;}
  .recurso-url{font-size:11px;color:var(--muted);margin-top:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  footer{background:white;border-top:1.5px solid var(--border);padding:28px;text-align:center;color:var(--muted);font-size:13px;margin-top:60px;}
  @media(max-width:600px){
    .hero{padding:50px 20px 36px;}.section{padding:40px 16px;}
    .modal{padding:26px 20px;}.write-container,.post-full{padding:28px 16px;}
  }
</style>
</head>
<body>

<!-- LOADING -->
<div class="loading-overlay" id="loading-overlay">
  <div class="spinner"></div>
  <div class="loading-text" id="loading-text">Conectando con Firebase…</div>
</div>

<!-- TOAST -->
<div class="toast-container" id="toast-container"></div>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <button class="logo" onclick="goHome()">
      <span>💧</span> Amigos de 5° Hugo Leonelli
    </button>
    <div class="header-nav">
      <div id="fb-status-badge" class="fb-status connecting"><div class="fb-dot"></div><span id="fb-status-text">Conectando…</span></div>
      <div id="user-badge"><span id="badge-avatar">👤</span><span id="badge-name"></span></div>
      <button class="btn-header btn-outline-white" onclick="goRecursos()" style="background:rgba(251,191,36,.25);border-color:rgba(251,191,36,.6)">🎮 Recursos</button>
      <button class="btn-header btn-outline-white" id="btn-login-header" onclick="openLogin()">Ingresar</button>
      <button class="btn-header btn-white" id="btn-logout-header" onclick="logout()" style="display:none">Salir</button>
    </div>
  </div>
</header>

<!-- ========== HOME ========== -->
<div id="view-home" class="view active">
