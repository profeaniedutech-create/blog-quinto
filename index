// ========== INIT ==========
async function init(){
  showLoading(true,'Conectando con Firebase…');
  setFbStatus('connecting');
  try{
    startListeners();
    await new Promise(resolve=>{
      const unsub=onSnapshot(query(collection(db,'posts'),limit(1)),()=>{unsub();resolve();},()=>resolve());
      setTimeout(resolve,5000);
    });
    loadSession();
    renderCategoryTabs();
    renderHome();
    setFbStatus('online');
  }catch(e){
    setFbStatus('offline');
    showToast('No se pudo conectar con Firebase','error',6000);
  }finally{
    showLoading(false);
  }
}
init();
