// ========== HELPERS ==========
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2); }
const COLORS=['#3B82F6','#8B5CF6','#0D9488','#F59E0B','#F43F5E','#06B6D4','#84CC16','#EC4899'];
function studentColor(id){ let n=0;for(const c of(id||''))n+=c.charCodeAt(0);return COLORS[n%COLORS.length]; }
function initials(n,a){ return((n||'')[0]||'').toUpperCase()+((a||'')[0]||'').toUpperCase(); }
function getSecByName(name){ return state.sections.find(s=>s.name===name); }
function esc(s){ return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function formatDate(ts){ return new Date(ts).toLocaleDateString('es-AR',{day:'numeric',month:'short',year:'numeric'}); }
function showErr(el,msg){ el.textContent=msg;el.style.display='block'; }
function safeUrl(url){
  try{ const u=new URL(url);if(u.protocol==='http:'||u.protocol==='https:')return u.href; }catch(e){}return '#';
}
const CTYPE_LABELS={texto:'📝 Texto',imagen:'🖼️ Imagen',audio:'🎵 Audio',video:'🎬 Video',documento:'📄 Documento',enlace:'🔗 Enlace'};
const FILE_HINTS={imagen:'JPG, PNG, GIF, WebP (máx. 10 MB)',audio:'MP3, WAV, OGG (máx. 50 MB)',video:'MP4, WebM (máx. 200 MB)',documento:'PDF, DOC, DOCX, PPT, XLS, TXT (máx. 20 MB)'};
const FILE_ACCEPTS={imagen:'image/*',audio:'audio/*',video:'video/*',documento:'.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt'};
const FILE_MAX_MB={imagen:10,audio:50,video:200,documento:20};

// ========== SHA-256 ==========
async function sha256(msg){
  const buf=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(msg));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

