  const ctypeEl=Array.from(document.querySelectorAll('.ctype-tab')).find(el=>el.getAttribute('onclick')&&el.getAttribute('onclick').includes("'"+ctype+"'"));
  setCType(ctype,ctypeEl);
  if(post.fileUrl){
    document.getElementById('file-preview-area').innerHTML=`<div class="file-preview"><span class="file-icon">📁</span><span class="file-name">${esc(post.fileName||'archivo')}</span><span style="font-size:12px;color:var(--teal);flex-shrink:0">☁️ ya subido</span></div>`;
  }
  showView('write');
}
async function deleteCurrentPost(){
  if(!confirm('¿Seguro que querés eliminar esta publicación?'))return;
  showLoading(true,'Eliminando…');
  try{await fbDeletePost(state.currentPostId);goHome();showToast('Publicación eliminada','');}
  catch(e){showToast('Error al eliminar: '+e.message,'error');}
  finally{showLoading(false);}
}

// ========== SUBMIT POST ==========
async function submitPost(){
  const title=document.getElementById('post-title-input').value.trim();
  const cat=document.getElementById('post-cat-input').value;
  const ctype=state.currentCType;
  const body=document.getElementById('post-body-input').value.trim();
  const link=document.getElementById('post-link-input').value.trim();
  const linkDesc=document.getElementById('link-desc').value.trim();
  const fileCaption=document.getElementById('file-caption').value.trim();
  const err=document.getElementById('write-error');
  err.style.display='none';
  if(!title){showErr(err,'Poné un título.');return;}
  if(!cat){showErr(err,'Elegí un proyecto.');return;}
  if(ctype==='texto'&&!body){showErr(err,'Escribí algo en el contenido.');return;}
  if(ctype==='enlace'&&!link){showErr(err,'Ingresá un enlace.');return;}
  if(ctype==='enlace'&&safeUrl(link)==='#'){showErr(err,'El enlace debe comenzar con http:// o https://');return;}
  const needsFile=['imagen','audio','video','documento'].includes(ctype);
  if(needsFile&&!state.uploadedFile&&!state.uploadedFileUrl&&!state.editingPostId){showErr(err,'Seleccioná un archivo.');return;}
  const btn=document.getElementById('btn-submit-post');
  btn.disabled=true;btn.textContent='Guardando…';
  showLoading(true,'Guardando publicación…');
  try{
    let fileUrl=state.uploadedFileUrl||null,fileName=null,fileStoragePath=null;
    if(needsFile&&state.uploadedFile){
      showLoading(true,'Subiendo archivo…');
      const postId=state.editingPostId||uid();
      const result=await uploadFile(state.uploadedFile.file,postId);
      fileUrl=result.url;fileName=state.uploadedFile.name;fileStoragePath=result.path;
    } else if(needsFile&&state.editingPostId){
      const existing=state.posts.find(p=>p.id===state.editingPostId);
      if(existing){fileName=existing.fileName||null;fileStoragePath=existing.fileStoragePath||null;}
    }
    await fbSavePost({
      title,category:cat,ctype,
      body:ctype==='texto'?body:'',
      link:ctype==='enlace'?link:'',
      linkDesc:ctype==='enlace'?linkDesc:'',
      fileUrl:needsFile?fileUrl:null,
      fileName:needsFile?fileName:null,
      fileStoragePath:needsFile?fileStoragePath:null,
      fileCaption:needsFile?fileCaption:'',
    });
    state.editingPostId=null;
    goHome();showToast('¡Publicación guardada! 🎉','success');
  }catch(e){
    showErr(err,'Error al guardar: '+e.message);
    showToast('Error: '+e.message,'error');
  }finally{
    btn.disabled=false;btn.textContent='💾 Publicar';
    showLoading(false);
  }
}

// ========== SECTIONS ==========
let _selEmoji='💧';
let _selColor={bg:'#F0FDFA',color:'#134E4A',border:'#99F6E4'};
function openAddSection(){
  document.getElementById('new-section-name').value='';
  document.getElementById('section-emoji-input').value='';
  document.getElementById('add-section-error').style.display='none';
  document.getElementById('add-section-success').style.display='none';
  _selEmoji='💧';_selColor={bg:'#F0FDFA',color:'#134E4A',border:'#99F6E4'};
  document.querySelectorAll('.emoji-opt').forEach(e=>e.style.border='2px solid transparent');
  document.querySelectorAll('.color-opt').forEach(c=>c.style.border='3px solid transparent');
  document.getElementById('overlay-add-section').classList.add('open');
}
function closeAddSection(){ document.getElementById('overlay-add-section').classList.remove('open'); }
function selectEmoji(el){
  document.querySelectorAll('.emoji-opt').forEach(e=>e.style.border='2px solid transparent');
  el.style.border='2px solid var(--teal)';_selEmoji=el.dataset.e;
  document.getElementById('section-emoji-input').value='';
}
function selectColor(el){
  document.querySelectorAll('.color-opt').forEach(c=>c.style.border='3px solid transparent');
  el.style.border='3px solid var(--text)';
  _selColor={bg:el.dataset.bg,color:el.dataset.color,border:el.dataset.border};
}
async function saveSection(){
  const name=document.getElementById('new-section-name').value.trim();
  const customEmoji=document.getElementById('section-emoji-input').value.trim();
  const err=document.getElementById('add-section-error');
  const suc=document.getElementById('add-section-success');
  err.style.display='none';suc.style.display='none';
  if(!name){showErr(err,'Ingresá el nombre del proyecto.');return;}
  if(state.sections.find(s=>s.name.toLowerCase()===name.toLowerCase())){showErr(err,'Ya existe ese proyecto.');return;}
  try{
    await fbSaveSection({id:uid(),name,emoji:customEmoji||_selEmoji||'📂',bg:_selColor.bg,color:_selColor.color,border:_selColor.border});
    suc.textContent=`✅ Proyecto "${name}" creado.`;suc.style.display='block';
    document.getElementById('new-section-name').value='';
    setTimeout(closeAddSection,1300);
  }catch(e){showErr(err,'Error: '+e.message);}
}
async function removeSection(id){
  const s=state.sections.find(sec=>sec.id===id);if(!s)return;
  if(!confirm(`¿Eliminar el proyecto "${s.name}"?`))return;
  try{await fbDeleteSection(id);showToast('Proyecto eliminado','');}
  catch(e){showToast('Error: '+e.message,'error');}
}

// ========== ADMIN ==========
function renderAdmin(){
  const sCount=state.students.length;
  document.getElementById('a-stat-students').textContent=sCount;
  document.getElementById('a-stat-slots').textContent=Math.max(0,MAX_STUDENTS-sCount);
  document.getElementById('a-stat-posts').textContent=state.posts.length;
  document.getElementById('a-stat-sections').textContent=state.sections.length;
  document.getElementById('sections-pills').innerHTML=state.sections.map(s=>
    `<span class="section-pill" style="background:${s.bg};color:${s.color};border-color:${s.border}">
      ${s.emoji} ${esc(s.name)}
      <button onclick="w.removeSection('${esc(s.id)}')">×</button>
    </span>`
  ).join('')||'<p style="color:var(--muted);font-size:14px">No hay proyectos.</p>';
  const tbody=document.getElementById('students-tbody');
  if(!state.students.length){
    tbody.innerHTML=`<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:30px">No hay alumnos registrados.</td></tr>`;
  } else {
    tbody.innerHTML=state.students.map((s,i)=>{
      const pc=state.posts.filter(p=>p.authorId===s.id).length;
      const color=studentColor(s.id);
      return `<tr>
        <td style="color:var(--muted)">${i+1}</td>
        <td><div style="display:flex;align-items:center;gap:8px"><div class="avatar-mini" style="background:${color}">${initials(s.nombre,s.apellido)}</div>${esc(s.nombre)} ${esc(s.apellido)}</div></td>
        <td><span class="badge badge-green">Activo</span></td>
        <td><strong>${pc}</strong></td>
        <td><div style="display:flex;gap:6px">
          <button class="btn-sm btn-success" onclick="w.openEditStudent('${esc(s.id)}')">✏️</button>
          <button class="btn-sm btn-danger" onclick="w.removeStudent('${esc(s.id)}')">🗑</button>
        </div></td>
      </tr>`;
    }).join('');
  }
  const ptbody=document.getElementById('admin-posts-tbody');
  if(!state.posts.length){
    ptbody.innerHTML=`<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:30px">Sin publicaciones.</td></tr>`;
  } else {
    ptbody.innerHTML=state.posts.map(p=>{
      const s=getSecByName(p.category)||{bg:'#F1F5F9',color:'#475569'};
      return `<tr>
        <td style="font-weight:700">${esc(p.title)}</td>
        <td>${CTYPE_LABELS[p.ctype||'texto']||''}</td>
        <td>${esc(p.authorName)}</td>
        <td><span class="badge" style="background:${s.bg};color:${s.color}">${esc(p.category)}</span></td>
        <td style="color:var(--muted)">${formatDate(p.date)}</td>
        <td><button class="btn-sm btn-danger" onclick="w.adminDeletePost('${esc(p.id)}')">🗑</button></td>
      </tr>`;
    }).join('');
  }
}
async function adminDeletePost(id){
  if(!confirm('¿Eliminar esta publicación?'))return;
  try{await fbDeletePost(id);showToast('Eliminada','');}
  catch(e){showToast('Error: '+e.message,'error');}
}

// ========== STUDENT CRUD ==========
function openAddStudent(){
  state.editingStudentId=null;
  document.getElementById('add-student-modal-title').textContent='➕ Agregar alumno';
  document.getElementById('new-student-nombre').value='';
  document.getElementById('new-student-apellido').value='';
  document.getElementById('add-student-error').style.display='none';
  document.getElementById('add-student-success').style.display='none';
  document.getElementById('btn-save-student').textContent='Agregar alumno';
  document.getElementById('overlay-add-student').classList.add('open');
}
function openEditStudent(id){
  const s=state.students.find(st=>st.id===id);if(!s)return;
  state.editingStudentId=id;
  document.getElementById('add-student-modal-title').textContent='✏️ Editar alumno';
  document.getElementById('new-student-nombre').value=s.nombre;
  document.getElementById('new-student-apellido').value=s.apellido;
  document.getElementById('add-student-error').style.display='none';
  document.getElementById('add-student-success').style.display='none';
  document.getElementById('btn-save-student').textContent='Guardar cambios';
  document.getElementById('overlay-add-student').classList.add('open');
}
function closeAddStudent(){ document.getElementById('overlay-add-student').classList.remove('open'); }
async function saveStudent(){
  const n=document.getElementById('new-student-nombre').value.trim();
  const a=document.getElementById('new-student-apellido').value.trim();
  const err=document.getElementById('add-student-error');
  const suc=document.getElementById('add-student-success');
  err.style.display='none';suc.style.display='none';
  if(!n||!a){showErr(err,'Completá nombre y apellido.');return;}
  try{
    if(state.editingStudentId){
      await fbSaveStudent(n,a,state.editingStudentId);
      suc.textContent=`✅ ${n} ${a} actualizado.`;suc.style.display='block';
      setTimeout(closeAddStudent,1200);
    } else {
      if(state.students.find(s=>s.nombre.toLowerCase()===n.toLowerCase()&&s.apellido.toLowerCase()===a.toLowerCase())){showErr(err,'Ya existe ese alumno.');return;}
      if(state.students.length>=MAX_STUDENTS){showErr(err,`Límite de ${MAX_STUDENTS} alumnos.`);return;}
      await fbSaveStudent(n,a);
      suc.textContent=`✅ ${n} ${a} agregado.`;suc.style.display='block';
      document.getElementById('new-student-nombre').value='';
      document.getElementById('new-student-apellido').value='';
      setTimeout(()=>{suc.style.display='none';},1800);
    }
  }catch(e){showErr(err,'Error: '+e.message);}
}
async function removeStudent(id){
  const s=state.students.find(st=>st.id===id);if(!s)return;
  if(!confirm(`¿Quitar a ${s.nombre} ${s.apellido}?`))return;
  try{await fbDeleteStudent(id);showToast(`${s.nombre} eliminado`,'');}
  catch(e){showToast('Error: '+e.message,'error');}
}

