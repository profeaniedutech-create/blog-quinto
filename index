async function doLogin(){
  const n=document.getElementById('login-nombre').value.trim();
  const a=document.getElementById('login-apellido').value.trim();
  const err=document.getElementById('login-error');
  if(!n||!a){showErr(err,'Escribí tu nombre y apellido.');return;}
  const found=state.students.find(s=>s.nombre.toLowerCase()===n.toLowerCase()&&s.apellido.toLowerCase()===a.toLowerCase());
  if(!found){showErr(err,'No encontramos ese nombre. Pedile a tu maestra que te registre.');return;}
  try{
    await signInAnonymously(auth);
    state.currentUser={id:found.id,name:found.nombre+' '+found.apellido,isAdmin:false};
    saveSession();closeLogin();afterLogin();
    showToast('¡Bienvenido/a, '+found.nombre+'! 🎉','success');
  }catch(e){
    showErr(err,'Error al ingresar. Intentá de nuevo.');
  }
}
async function doAdminLogin(){
  const n=document.getElementById('admin-nombre').value.trim();
  const a=document.getElementById('admin-apellido').value.trim();
  const dni=document.getElementById('admin-dni').value.trim();
  const err=document.getElementById('admin-login-error');
  if(!n||!a||!dni){showErr(err,'Completá nombre, apellido y DNI.');return;}
  // Construir contraseña Firebase como: nombre_apellido_dni (minúsculas, sin espacios)
  const pass=`${n.toLowerCase().replace(/\s+/g,'_')}_${a.toLowerCase().replace(/\s+/g,'_')}_${dni}`;
  try{
    await signInWithEmailAndPassword(auth,ADMIN_EMAIL,pass);
    state.currentUser={id:'admin',name:'Maestra',isAdmin:true};
    saveSession();closeAdminLogin();afterLogin();goAdmin();
    showToast('Bienvenida, maestra 👩‍🏫','success');
  }catch(e){
    if(e.code==='auth/wrong-password'||e.code==='auth/user-not-found'||e.code==='auth/invalid-credential'){
      showErr(err,'Los datos no son correctos. Verificá nombre, apellido y DNI.');
    } else {
      showErr(err,'Error: '+e.message);
    }
  }
}
function afterLogin(restore=false){
