// ========== CONTENT TYPE ==========
function setCType(type,el){
  state.currentCType=type;
  document.querySelectorAll('.ctype-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  document.getElementById('ctype-texto').style.display=(type==='texto')?'':'none';
  document.getElementById('ctype-file').style.display=(['imagen','audio','video','documento'].includes(type))?'':'none';
  document.getElementById('ctype-enlace').style.display=(type==='enlace')?'':'none';
  if(['imagen','audio','video','documento'].includes(type)){
    document.getElementById('upload-hint').textContent=FILE_HINTS[type]||'';
    document.getElementById('upload-icon').textContent=type==='imagen'?'🖼️':type==='audio'?'🎵':type==='video'?'🎬':'📄';
    document.getElementById('file-input').accept=FILE_ACCEPTS[type]||'*/*';
    state.uploadedFile=null;state.uploadedFileUrl=null;
    document.getElementById('file-preview-area').innerHTML='';
  }
}
function handleFile(input){
  const file=input.files[0];if(!file)return;
  const maxMB=FILE_MAX_MB[state.currentCType]||20;
  if(file.size>maxMB*1024*1024){showToast(`Máximo ${maxMB} MB para este tipo.`,'warning',5000);input.value='';return;}
  state.uploadedFile={name:file.name,type:file.type,file};
  const icon=file.type.startsWith('image/')?'🖼️':file.type.startsWith('audio/')?'🎵':file.type.startsWith('video/')?'🎬':'📄';
  const sizeMB=(file.size/1024/1024).toFixed(1);
  document.getElementById('file-preview-area').innerHTML=
    `<div class="file-preview"><span class="file-icon">${icon}</span><span class="file-name">${esc(file.name)}</span><span style="color:var(--muted);font-size:12px;flex-shrink:0">${sizeMB} MB</span><button class="remove-file" onclick="w.removeFile()">×</button></div>`;
}
